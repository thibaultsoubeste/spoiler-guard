{
  "manifest_version": 2,
  "name": "Spoiler Guard",
  "version": "2.0",
  "description": "Hides spoiler elements (preview thumbnails, progress bar, time) on Twitch and YouTube",
  "icons": {
    "48": "icon.svg"
  },
  "browser_action": {
    "default_icon": "icon.svg",
    "default_title": "Spoiler Guard: ON"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content-twitch.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content-youtube.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": ["spoiler-guard.css", "spoiler-guard-youtube.css"],
  "permissions": ["tabs", "*://*.cloudfront.net/*"]
}
