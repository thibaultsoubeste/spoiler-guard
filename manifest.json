{
  "manifest_version": 2,
  "name": "Spoiler Guard",
  "version": "2.2",
  "description": "Hides spoiler elements (preview thumbnails, progress bar, time) on Twitch and YouTube",
  "icons": {
    "48": "icon.svg"
  },
  "browser_action": {
    "default_icon": "icon.svg",
    "default_title": "Spoiler Guard: ON"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["slider.js", "content-twitch.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["slider.js", "content-youtube.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": ["spoiler-guard.css", "spoiler-guard-youtube.css", "slider.css"],
  "permissions": ["tabs", "*://*.cloudfront.net/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "spoiler-guard@thibaultsoubeste",
      "update_url": "https://thibaultsoubeste.github.io/spoiler-guard/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
